#!/bin/bash

# Pre-push hook: Enforce sanitization rules before pushing to GitHub
# Prevents commits containing prohibited AI-related references
# Excludes hook files themselves

PROHIBITED_TERMS="copilot|github-copilot|gemini|openai|claude|chatgpt|antigravity"

# Get the range of commits being pushed
while read local_ref local_oid remote_ref remote_oid; do
    if [ "$remote_oid" != "0000000000000000000000000000000000000000" ]; then
        # Remote ref exists, check commits between remote and local
        MERGE_BASE=$(git merge-base "$remote_oid" "$local_oid")
        COMMITS="$MERGE_BASE..$local_oid"
    else
        # New remote ref, check all commits
        COMMITS=$(git rev-list "$local_oid")
    fi

    # Search for prohibited terms in commits being pushed
    if git log $COMMITS --all-match --grep="$PROHIBITED_TERMS" -i 2>/dev/null | grep -q .; then
        echo "ERROR: Pre-push hook blocked push to $(echo $remote_ref | cut -d/ -f3)"
        echo "Prohibited AI-related term found in commit message:"
        git log $COMMITS --all-match --grep="$PROHIBITED_TERMS" -i --oneline
        exit 1
    fi

    # Search for prohibited terms in file content, excluding hook files
    if git diff "$MERGE_BASE".."$local_oid" -- ":(exclude).githooks/**" 2>/dev/null | grep -q -i "$PROHIBITED_TERMS"; then
        echo "ERROR: Pre-push hook blocked push to $(echo $remote_ref | cut -d/ -f3)"
        echo "Prohibited AI-related term found in code:"
        git diff "$MERGE_BASE".."$local_oid" -- ":(exclude).githooks/**" 2>/dev/null | grep -n -i "$PROHIBITED_TERMS" | head -5
        exit 1
    fi
done

exit 0
